# Jan local API. Ce mode utilise /v1/messages, plus stable si /v1/chat/completions time out.
URL=http://127.0.0.1:1337/v1
MODEL=your-jan-model-id
API_KEY=your-jan-api-key
API_TYPE=anthropic
LLM_TIMEOUT=240
LLM_MAX_TOKENS=450

